{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "run_ledger.schema.json",
  "title": "Run Ledger Line",
  "description": "One line per queue item's full run — the master record that token_ledger.jsonl and skill_trust.jsonl entries hang off of. Written by the coordinator at done-transition, same as the other three ledgers (LOOP_POLICY.md).",
  "type": "object",
  "required": ["item_id", "lane", "profile", "skill", "created", "status", "escalated", "budget_class"],
  "properties": {
    "item_id": {"type": "string", "pattern": "^Q-[0-9]{4}-[0-9]{4}$"},
    "lane": {"type": "string", "enum": ["revenue", "marketing", "delivery", "ops"]},
    "profile": {"type": "string", "enum": ["aos-orchestrator", "aos-revenue", "aos-marketing", "aos-delivery", "aos-ops"]},
    "skill": {"type": "string"},
    "created": {"type": "string", "format": "date-time"},
    "done": {"type": "string", "format": "date-time"},
    "status": {"type": "string", "enum": ["inbox", "agent_todo", "agent_working", "needs_input", "human_review", "done", "blocked", "cancelled"]},
    "escalated": {"type": "boolean"},
    "review": {"type": "string", "enum": ["ACCEPT", "REVISE", "pending"]},
    "budget_class": {"type": "string", "enum": ["light", "standard", "heavy"]},
    "receipt": {"type": "string"},
    "memory_promotion": {"type": "array", "items": {"type": "string"}, "description": "Explicit even if empty — never silently omitted, per MEMORY_PROMOTION_POLICY.md."}
  }
}
