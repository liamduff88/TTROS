{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "token_ledger.schema.json",
  "title": "Token Ledger Line",
  "description": "One line per completed receipt's token_usage block, per TOKEN_POLICY.md §8.2. Numbers come from harness/API usage fields only — never estimated. Unreportable components go in unavailable by name.",
  "type": "object",
  "required": ["item_id", "lane", "profile", "timestamp", "escalated", "model_requested", "model_confirmed", "budget_class", "token_usage"],
  "properties": {
    "item_id": {"type": "string", "pattern": "^Q-[0-9]{4}-[0-9]{4}$"},
    "lane": {"type": "string", "enum": ["revenue", "marketing", "delivery", "ops"]},
    "profile": {"type": "string", "enum": ["aos-orchestrator", "aos-revenue", "aos-marketing", "aos-delivery", "aos-ops"]},
    "timestamp": {"type": "string", "format": "date-time"},
    "escalated": {"type": "boolean"},
    "model_requested": {"type": "string"},
    "model_confirmed": {"type": "string"},
    "budget_class": {"type": "string", "enum": ["light", "standard", "heavy"]},
    "token_usage": {
      "type": "object",
      "required": ["orchestrator", "subagents", "workbenches", "totals", "est_cost_usd", "unavailable"],
      "properties": {
        "orchestrator": {
          "type": "object",
          "required": ["input", "output"],
          "properties": {"input": {"type": "integer", "minimum": 0}, "output": {"type": "integer", "minimum": 0}}
        },
        "subagents": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["role", "model", "input", "output"],
            "properties": {
              "role": {"type": "string"},
              "model": {"type": "string"},
              "input": {"type": "integer", "minimum": 0},
              "output": {"type": "integer", "minimum": 0}
            }
          }
        },
        "workbenches": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["tool", "input", "output", "source"],
            "properties": {
              "tool": {"type": "string", "enum": ["claude-code", "codex", "antigravity"]},
              "session_id": {"type": "string"},
              "input": {"type": "integer", "minimum": 0},
              "output": {"type": "integer", "minimum": 0},
              "source": {"type": "string", "enum": ["reported", "unavailable"]}
            }
          }
        },
        "totals": {
          "type": "object",
          "required": ["input", "output"],
          "properties": {"input": {"type": "integer", "minimum": 0}, "output": {"type": "integer", "minimum": 0}}
        },
        "est_cost_usd": {"type": "number", "minimum": 0},
        "unavailable": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
