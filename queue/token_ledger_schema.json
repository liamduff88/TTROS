{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "token_ledger.schema.json",
  "title": "Token Ledger Line",
  "description": "One line per item invocation/session token_usage block. Invocation usage is reconciled at supervised process exit independently of queue status. Numbers come from structured harness/CLI evidence only — never estimated.",
  "$comment": "Reconciled 2026-07-07: item_id now accepts the live AOS- id scheme (tools/aos-queue.py) alongside the legacy Q- scheme; lane/profile enums widened to the real owner-derived set (lane_profiles.json owners + workbench/unassigned + default route). Numbers still come from harness/API usage only.",
  "type": "object",
  "required": ["item_id", "lane", "profile", "timestamp", "escalated", "model_requested", "model_confirmed", "budget_class", "token_usage"],
  "properties": {
    "item_id": {"type": "string", "pattern": "^(AOS|Q)-[0-9]{4}-[0-9]{4}$"},
    "session_id": {"type": "string", "minLength": 1, "description": "Codex session/thread identity for invocation-level deduplication when available."},
    "invocation_id": {"type": "string", "minLength": 1},
    "event": {"type": "string"},
    "lane": {"type": "string", "enum": ["revenue", "marketing", "delivery", "operations", "ops", "orchestrator", "hermes", "codex", "claude", "unassigned"]},
    "profile": {"type": "string", "enum": ["aos-orchestrator", "aos-revenue", "aos-marketing", "aos-delivery", "aos-ops", "default"]},
    "timestamp": {"type": "string", "format": "date-time"},
    "escalated": {"type": "boolean"},
    "model_requested": {"type": "string"},
    "model_confirmed": {"type": "string"},
    "budget_class": {"type": "string", "enum": ["light", "standard", "heavy"]},
    "token_usage": {
      "type": "object",
      "required": ["orchestrator", "subagents", "workbenches", "totals", "est_cost_usd", "unavailable"],
      "properties": {
        "orchestrator": {
          "type": "object",
          "required": ["input", "output"],
          "properties": {"input": {"type": "integer", "minimum": 0}, "output": {"type": "integer", "minimum": 0}}
        },
        "subagents": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["role", "model", "input", "output"],
            "properties": {
              "role": {"type": "string"},
              "model": {"type": "string"},
              "input": {"type": "integer", "minimum": 0},
              "output": {"type": "integer", "minimum": 0}
            }
          }
        },
        "workbenches": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["tool", "input", "output", "source"],
            "properties": {
              "tool": {"type": "string", "enum": ["claude-code", "codex", "antigravity"]},
              "session_id": {"type": "string"},
              "input": {"type": "integer", "minimum": 0},
              "output": {"type": "integer", "minimum": 0},
              "source": {"type": "string", "enum": ["reported", "unavailable"]}
            }
          }
        },
        "totals": {
          "type": "object",
          "required": ["input", "output"],
          "properties": {"input": {"type": "integer", "minimum": 0}, "output": {"type": "integer", "minimum": 0}}
        },
        "est_cost_usd": {"type": "number", "minimum": 0},
        "unavailable": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
