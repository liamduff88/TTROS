{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-os.local/schemas/receipt.schema.json",
  "title": "Agentic OS Work Receipt",
  "type": "object",
  "required": [
    "path",
    "created_at"
  ],
  "properties": {
    "path": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
